{
  "skill_name": "video-to-summary-v2",
  "evals": [
    {
      "id": 1,
      "name": "bilibili-standard-url",
      "prompt": "帮我总结这个B站视频: https://www.bilibili.com/video/BV1GJ411x7h7",
      "expected_output": "识别B站平台，下载视频，提取音频，生成Markdown格式总结",
      "assertions": [
        {
          "name": "detects_bilibili",
          "description": "正确识别B站平台",
          "type": "output_contains",
          "expected": "bilibili"
        },
        {
          "name": "generates_markdown",
          "description": "生成Markdown总结文件",
          "type": "file_exists",
          "expected": ".md"
        },
        {
          "name": "has_summary_structure",
          "description": "总结包含标准结构",
          "type": "output_contains",
          "expected": "## 概述"
        }
      ]
    },
    {
      "id": 2,
      "name": "bilibili-short-link",
      "prompt": "视频转文字：https://b23.tv/BV1xx411c7mD",
      "expected_output": "识别B站短链接并处理",
      "assertions": [
        {
          "name": "handles_short_link",
          "description": "正确处理B站短链接",
          "type": "output_contains",
          "expected": "bilibili"
        }
      ]
    },
    {
      "id": 3,
      "name": "xiaohongshu-discovery-url",
      "prompt": "提取这个小红书视频的内容: https://www.xiaohongshu.com/discovery/item/6782a00000000000010300000",
      "expected_output": "识别小红书平台，使用优化下载策略，生成文字总结",
      "assertions": [
        {
          "name": "detects_xiaohongshu",
          "description": "正确识别小红书平台",
          "type": "output_contains",
          "expected": "xiaohongshu"
        },
        {
          "name": "uses_custom_headers",
          "description": "使用自定义headers下载",
          "type": "output_contains",
          "expected": "referer"
        }
      ]
    },
    {
      "id": 4,
      "name": "xiaohongshu-xhslink",
      "prompt": "帮我转写这个小红薯链接的视频：https://xhslink.com/abc123",
      "expected_output": "识别小红书短链接并处理",
      "assertions": [
        {
          "name": "detects_xiaohongshu_short",
          "description": "正确识别小红书短链接",
          "type": "output_contains",
          "expected": "xiaohongshu"
        }
      ]
    },
    {
      "id": 5,
      "name": "casual-request",
      "prompt": "看看这个视频讲了什么 https://www.bilibili.com/video/BV1test123",
      "expected_output": "识别用户意图并处理B站视频",
      "assertions": [
        {
          "name": "triggers_correctly",
          "description": "正确触发skill处理",
          "type": "output_contains",
          "expected": "bilibili"
        }
      ]
    }
  ]
}
